# MongoDB Configuration (Required)
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB=your_database_name

# Gemini AI API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# App URL (Required for production)
APP_URL=https://your-app-name.vercel.app

# Access Codes for Pro Tier (Optional)
# Comma-separated list of access codes that grant Pro tier access
ACCESS_CODES=CODE1,CODE2,CODE3

# Marketplace URL (Required)
# URL where users can purchase Pro tier access
NEXT_PUBLIC_MARKETPLACE_URL=https://www.builtattic.com/products/vitruviai-pro-access?variant=47204727128299

# Stripe Configuration (Optional - if using Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRICE_ID=your_stripe_price_id
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
